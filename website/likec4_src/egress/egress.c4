model {
  extend egress {
    egress_app = service {
      title 'Egress Application'
      description 'Application providing data owners with the ability to approve or reject data egress'
    }
    
    keycloak = component {
      title 'Keycloak'
      description 'Authenticates requests througout the layer'
      icon https://upload.wikimedia.org/wikipedia/commons/2/29/Keycloak_Logo.png
    }
  }
}

views {
  view of egress {
    title 'Egress Service'
    include *
  }
}
