model {
    funnel = component {
        title 'Funnel'
    }
}

deployment {
    extend prod.vm2 {
        instanceOf tre {
            -> funnel 'Submit Job'
        }
        instanceOf egress
        instanceOf funnel {
            -> tre 'Return job result'
            -> protected_data 'Queries protected data'
        }
        instanceOf protected_data
    }
}
