deployment {
  environment prod {
    vm1 = virtual_machine 'External VM'
    vm2 = virtual_machine 'Internal VM'
  }
  extend prod.vm1 {
    harbor -> prod.vm2 'Pull images'
    revproxy -> submission 'Route web traffic'
  }
}


views {
  deployment view prod {
    title 'Deployment / Production'
    include prod.**
  }
}
