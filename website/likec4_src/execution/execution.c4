model {
  extend execution {
    funnel = component {
      title "TES Engine"
      description "TES compliant job engine"
      technology "e.g. Funnel, TESK"
      icon https://avatars.githubusercontent.com/u/6921777?v=4

      -> protected_data 'Queries protected data'
      -> tre.s3 'Stores job result'
    }
  }
}

views {
  view execution of execution {
    title 'TRE / Execution Service'
    include *
  }
}
